# CT artifact FastAPI service configuration.
#
# PowerShell example:
#   $env:CT_SERVER_DEVICE="cuda"
#   python Filter/Fastapi/CTDetectionServer.py

# cpu / cuda / empty for automatic inference wrapper default.
CT_SERVER_DEVICE=

# Optional explicit checkpoint path.
# 3D default: Filter/model/runs/metal_unet3d/best_unet3d_metal.pt
# 2D default: Filter/model/UNet2D方案/runs/unet2d/best_unet2d_metal.pt
CT_MODEL_WEIGHT_PATH=

# Model audit fields returned in result.json.
CT_MODEL_NAME=metal_unet3d
CT_MODEL_VERSION=v1.0.0

# Local storage.
CT_UPLOAD_DIR=
CT_OUTPUT_ROOT=

# 3D service only.
CT_SERVER_PATCH_SIZE=32,128,128
CT_SERVER_OVERLAP=0.5

# Shared threshold.
CT_SERVER_THRESHOLD=0.35
