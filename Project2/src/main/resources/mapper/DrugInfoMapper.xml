<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.neuedu.his.mapper.DrugInfoMapper">

    <resultMap id="DrugInfoResultMap" type="DrugInfo">
        <id property="id" column="id"/>
        <result property="drugCode" column="drug_code"/>
        <result property="drugName" column="drug_name"/>
        <result property="drugFormat" column="drug_format"/>
        <result property="drugUnit" column="drug_unit"/>
        <result property="stockNum" column="stock_num"/>
        <result property="drugPrice" column="drug_price"/>
        <result property="manufacturer" column="manufacturer"/>
        <result property="drugType" column="drug_type"/>
    </resultMap>

    <select id="selectByCondition" resultMap="DrugInfoResultMap">
        SELECT * FROM drug_info
        WHERE 1=1
        <if test="drugName != null and drugName != ''">AND drug_name LIKE CONCAT('%', #{drugName}, '%')</if>
        <if test="drugType != null and drugType != ''">AND drug_type = #{drugType}</if>
        <if test="stockAlert != null and stockAlert">AND stock_num &lt; 10</if>
        ORDER BY drug_name ASC
    </select>

</mapper>