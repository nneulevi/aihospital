### ========================================
### 智慧云脑诊疗平台 - API测试集合（合并后版本）
### ========================================

### ---- 环境变量 ----
@baseUrl = http://localhost:8092
@token =
@newRegisterId =
@patientToken =

### ========================================
### 患者注册登录测试（协和模式）
### ========================================

### 1. 发送注册验证码
POST {{baseUrl}}/api/patient/send-code
Content-Type: application/json

{
  "phone": "13912345678",
  "codeType": "REGISTER"
}


### 2. 添加就诊人（注册 + 自动登录）
# @name authRegister
POST {{baseUrl}}/api/patient/auth/register
Content-Type: application/json

{
  "realName": "张三",
  "cardNumber": "11010119900307663X",
  "phone": "13912345678",
  "code": "062632",
  "gender": "男",
  "birthdate": "1990-03-07",
  "homeAddress": "北京市朝阳区XX路1号"
}

> {%
    if (response.status === 200) {
        client.global.set("patientToken", response.body.token);
        client.log("患者Token已保存: " + response.body.token.substring(0, 30) + "...");
        client.log("就诊卡号: " + response.body.caseNumber);
        client.log("患者ID: " + response.body.patientId);
    }
%}


### 3. 查看就诊人列表（需要token）
GET {{baseUrl}}/api/patient/list
Authorization: Bearer {{patientToken}}

### 3. 查看就诊人列表（需要token）
GET {{baseUrl}}/api/patient/list
