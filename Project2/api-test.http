### ========================================
### 医生/管理员验证码登录测试
### ========================================

### 6. 发送医生登录验证码
# 注意：phone 必须是 employee 表中已存在的手机号
POST {{baseUrl}}/api/auth/send-code
Content-Type: application/json

{
  "phone": "13800138001",
  "codeType": "DOCTOR_LOGIN"
}

### 7. 医生验证码登录
# @name doctorLoginByCode
POST {{baseUrl}}/api/auth/login-by-code
Content-Type: application/json

{
  "phone": "13800138001",
  "verifyCode": "170744",
  "loginType": "DOCTOR"
}

> {%
    if (response.status === 200) {
        client.global.set("token", response.body.token);
        client.log("医生Token已保存: " + response.body.token.substring(0, 30) + "...");
        client.log("医生姓名: " + response.body.realname);
        client.log("角色: " + response.body.roleType);
        client.log("科室ID: " + response.body.deptId);
    }
%}

### 8. 发送管理员登录验证码
POST {{baseUrl}}/api/auth/send-code
Content-Type: application/json

{
  "phone": "13800138004",
  "codeType": "ADMIN_LOGIN"
}

### 9. 管理员验证码登录
# @name adminLoginByCode
POST {{baseUrl}}/api/auth/login-by-code
Content-Type: application/json

{
  "phone": "13800138004",
  "verifyCode": "634756",
  "loginType": "ADMIN"
}

> {%
    if (response.status === 200) {
        client.global.set("adminToken", response.body.token);
        client.log("管理员Token已保存: " + response.body.token.substring(0, 30) + "...");
        client.log("管理员姓名: " + response.body.realname);
        client.log("角色: " + response.body.roleType);
    }
%}

### 10. 验证码登录 - 手机号未注册（应返回400）
POST {{baseUrl}}/api/auth/login-by-code
Content-Type: application/json

{
  "phone": "13999999999",
  "verifyCode": "123456",
  "loginType": "DOCTOR"
}

### 11. 验证码登录 - 验证码错误（应返回400）
POST {{baseUrl}}/api/auth/login-by-code
Content-Type: application/json

{
  "phone": "13800138001",
  "verifyCode": "000000",
  "loginType": "DOCTOR"
}

### 12. 验证码登录 - 角色权限不符（应返回400）
# 假设 13800138001 的角色是 DOCTOR，但用 ADMIN 登录
POST {{baseUrl}}/api/auth/login-by-code
Content-Type: application/json

{
  "phone": "13800138001",
  "verifyCode": "123456",
  "loginType": "ADMIN"
}


### ========================================
### 管理员端 - 新增接口测试
### ========================================

### 1. 获取所有科室列表
GET {{baseUrl}}/api/admin/department/list
Authorization: Bearer {{adminToken}}

### 2. 获取所有职员列表
GET {{baseUrl}}/api/admin/employee/list
Authorization: Bearer {{adminToken}}

### 3. 获取所有医生列表
GET {{baseUrl}}/api/admin/employee/doctors
Authorization: Bearer {{adminToken}}

### 4. 创建医生档案
POST {{baseUrl}}/api/admin/employee/create
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "realname": "赵敏",
  "phone": "13800138006",
  "password": "123456",
  "roleType": "DOCTOR",
  "deptmentId": 6,
  "titleLevel": "主治医师",
  "enabled": true
}

### 5. 创建管理员档案
POST {{baseUrl}}/api/admin/employee/create
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "realname": "系统管理员C",
  "phone": "13800138007",
  "password": "123456",
  "roleType": "ADMIN",
  "deptmentId": null,
  "titleLevel": "超级管理员",
  "enabled": true
}

### 6. 医生统计（接诊量 + 复查率）
GET {{baseUrl}}/api/admin/statistics/doctor
Authorization: Bearer {{adminToken}}

### 7. 部门统计
GET {{baseUrl}}/api/admin/statistics/dept
Authorization: Bearer {{adminToken}}


