POST {{baseUrl}}/api/patient/logout
Authorization: Bearer eyJhbGciOiJIUzI1NiJ9.eyJyb2xlVHlwZSI6IlBBVElFTlQiLCJ1c2VySWQiOjEsInVzZXJuYW1lIjoidXNlcl8xIiwic3ViIjoidXNlcl8xIiwiaWF0IjoxNzgxNzUwMzU0LCJleHAiOjE3ODE4MzY3NTR9.75gUp-NgH_9IWs4rYn2vO3GjfFQcaWKhRarfFBh27co












### ========================================
### 1. 健康检查
### ========================================

GET {{baseUrl}}/actuator/health

### ========================================
### 2. 查询可挂号医生
### ========================================

GET {{baseUrl}}/api/patient/doctors?deptId=1&visitDate=2026-05-23&noon=上午&pageNum=1&pageSize=10

### ========================================
### 3. 登录
### ========================================

# @name login
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "张建国",
  "password": "123456",
  "loginType": "DOCTOR"
}

> {%
    if (response.status === 200 && response.body.code === 200) {
        client.global.set("token", response.body.data.token);
        client.log("Token已保存");
    }
%}

### ========================================
### 4. 挂号
### ========================================

# @name register
POST {{baseUrl}}/api/patient/register
Content-Type: application/json

{
  "caseNumber": "HN202600001",
  "realName": "张三",
  "gender": "男",
  "cardNumber": "11010119900307663X",
  "birthdate": "1990-03-07",
  "phone": "13912345678",
  "homeAddress": "北京市朝阳区XX路1号",
  "deptId": 1,
  "doctorId": 1,
  "visitDate": "2026-05-23",
  "noon": "上午",
  "registLevelId": 1,
  "settleCategoryId": 2,
  "registMethod": "微信"
}

> {%
    if (response.status === 200 && response.body.code === 200) {
        client.global.set("newRegisterId", response.body.data);
        client.log("新挂号ID已保存: " + response.body.data);
    }
%}

### ========================================
### 5. 病历列表
### ========================================

GET {{baseUrl}}/api/patient/records?patientId=1&pageNum=1&pageSize=10
Authorization: Bearer {{token}}

### ========================================
### 6. 病历详情
### ========================================

GET {{baseUrl}}/api/patient/records/1
Authorization: Bearer {{token}}

### ========================================
### 7. 医生待诊列表
### ========================================

GET {{baseUrl}}/api/doctor/patients?doctorId=1&visitState=REGISTERED&pageNum=1&pageSize=10
Authorization: Bearer {{token}}

### ========================================
### 8. 保存病历
### ========================================

POST {{baseUrl}}/api/doctor/medical-record
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "registerId": 6,
  "readme": "头痛头晕3天",
  "present": "患者3天前无明显诱因出现头痛、头晕，呈阵发性",
  "presentTreat": "未治疗",
  "history": "高血压病史5年",
  "allergy": "无",
  "physique": "BP 140/90mmHg，神清",
  "proposal": "头颅CT检查",
  "careful": "避免劳累",
  "diagnosis": "高血压病"
}

### ========================================
### 9. AI诊断建议
### ========================================

POST {{baseUrl}}/api/ai/diagnosis/suggest
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "medicalRecordId": 1,
  "symptoms": "头痛头晕",
  "history": "高血压",
  "physique": "BP140/90"
}

### ========================================
### 10. 开检查申请
### ========================================

POST {{baseUrl}}/api/doctor/check-request
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "registerId": 6,
  "items": [
    {
      "medicalTechnologyId": 1,
      "checkInfo": "头颅CT平扫",
      "checkPosition": "头部"
    }
  ]
}

### ========================================
### 11. AI影像上传
### ========================================

POST {{baseUrl}}/api/ai/image/upload?checkRequestId=1&registerId=6
Content-Type: multipart/form-data; boundary=WebAppBoundary
Authorization: Bearer {{token}}

--WebAppBoundary
Content-Disposition: form-data; name="file"; filename="ct_test.jpg"
Content-Type: image/jpeg

< ./test-files/ct_test.jpg
--WebAppBoundary--

### ========================================
### 12. AI影像分析
### ========================================

POST {{baseUrl}}/api/ai/image/analyze
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "imageFileId": 1,
  "checkRequestId": 1
}

